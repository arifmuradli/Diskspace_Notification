<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
    <appSettings>
        <!-- Trigger threshold as a percentage of free space (e.g. 10 = warn below 10% free) -->
        <add key="DiskSpaceThresholdPercent" value="10" />
        <!-- Trigger threshold in gigabytes of free space (e.g. 5 = warn below 5 GB free) -->
        <add key="DiskSpaceThresholdGB" value="20" />
        <!-- Condition mode: % | GB | OR | AND
             %   = trigger only when free space is below DiskSpaceThresholdPercent
             GB  = trigger only when free space is below DiskSpaceThresholdGB
             OR  = trigger when either condition is met (default)
             AND = trigger only when both conditions are met simultaneously -->
        <add key="DiskSpaceCondition" value="GB" />
    </appSettings>
</configuration>